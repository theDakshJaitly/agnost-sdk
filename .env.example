# Copy this file to `.env` and fill in the values.
# `.env` is gitignored. Used by `npm run capture:openai` to produce the
# real-span fixture in test/fixtures/openai.spans.json.

# Required. Any OpenAI-compatible API key (OpenAI key, Groq key, etc).
OPENAI_API_KEY=

# Optional. Set if using an OpenAI-compatible endpoint other than OpenAI.
# Examples:
#   Groq:      https://api.groq.com/openai/v1
#   Together:  https://api.together.xyz/v1
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Model name as the chosen provider expects it.
# Groq examples:  llama-3.3-70b-versatile, llama-3.1-8b-instant
# OpenAI:         gpt-4o-mini
AGNOST_CAPTURE_MODEL=llama-3.3-70b-versatile

# What we record as gen_ai.system on the captured span. Stay honest about
# the real provider — the fixture is the proof artifact.
AGNOST_CAPTURE_PROVIDER=groq
